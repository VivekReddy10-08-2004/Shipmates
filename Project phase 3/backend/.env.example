# Copy this file to .env and fill in the values.
# Ask Jake for the real OpenAI key — don't commit your .env.

# ---- OpenAI (AI quiz/flashcard generation) ----
OPENAI_API_KEY=sk-...
AI_GENERATE_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# ---- Database (local MySQL) ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-local-mysql-password
MYSQL_DB=StudyBuddy

# ---- Session cookie signing key ----
# Generate a random 64+ byte hex string. One-liner:
#   python -c "import secrets; print(secrets.token_hex(64))"
SESSION_SECRET=replace-me-with-a-long-random-hex-string

# ---- Optional: auto-seed an admin user on first run ----
# Leave unset in dev; set both to create an admin.
# ADMIN_USERNAME=admin@example.com
# ADMIN_PASSWORD=change-me
